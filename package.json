{
  "name": "akashic-agent-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "npm run desktop:start",
    "build": "npm run build:desktop",
    "build:desktop": "npm --prefix desktop run build",
    "smoke": "npm run desktop:smoke",
    "desktop:build": "npm run build:desktop",
    "desktop:dev": "npm --prefix desktop run dev",
    "desktop:smoke:restart": "npm --prefix desktop run smoke:restart",
    "desktop:smoke": "npm --prefix desktop run smoke",
    "desktop:start": "npm --prefix desktop run start:built",
    "desktop:test": "node desktop/scripts/test-unit.mjs",
    "desktop:typecheck": "npm --prefix desktop run typecheck",
    "dev": "npm run desktop:dev",
    "lint": "eslint desktop/src desktop/renderer/src",
    "test": "npm run desktop:test",
    "typecheck": "npm --prefix desktop run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "tsx": "^4.23.1",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.59.1"
  }
