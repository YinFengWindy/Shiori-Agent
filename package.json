{
  "name": "akashic-agent-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "npm run desktop:start",
    "build": "npm run build:plugins && npm run build:desktop",
    "build:desktop": "npm --prefix desktop run build",
    "build:plugins": "node scripts/build-plugins.mjs",
    "build:watch": "node scripts/build-plugins.mjs --watch",
    "smoke": "npm run desktop:smoke:all",
    "desktop:build": "npm run build:desktop",
    "desktop:dev": "npm --prefix desktop run dev",
    "desktop:dev:smoke": "npm --prefix desktop run smoke:desktop",
    "desktop:smoke:all": "npm --prefix desktop run smoke",
    "desktop:smoke:ui": "npm --prefix desktop run build && npm --prefix desktop run smoke:desktop-ui",
    "desktop:smoke:restart": "npm --prefix desktop run smoke:restart",
    "desktop:smoke": "npm --prefix desktop run build && npm --prefix desktop run smoke:desktop",
    "desktop:start": "npm --prefix desktop run start:built",
    "desktop:typecheck": "npm --prefix desktop run typecheck",
    "dev": "npm run desktop:dev",
    "lint": "eslint \"frontend/dashboard/src/**/*.{ts,tsx}\" \"plugins/**/*.ts\" \"types/**/*.d.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.25.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.59.1",
    "vite": "^6.0.7"
  },
  "dependencies": {
    "@radix-ui/react-scroll-area": "^1.2.2",
    "clsx": "^2.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1",
    "tailwind-merge": "^2.6.0"
  }
}
