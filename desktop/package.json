{
  "name": "shiori-desktop",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "vite build --config renderer/vite.config.ts",
    "dev": "npm run build:main && npm run build:preload && node scripts/dev.mjs",
    "dev:renderer": "vite --config renderer/vite.config.ts",
    "smoke": "npm run build && npm run smoke:bridge && npm run smoke:host && npm run smoke:desktop",
    "smoke:bridge": "node scripts/smoke-bridge.mjs",
    "smoke:host": "node scripts/smoke-host.mjs",
    "smoke:restart": "node scripts/smoke-restart.mjs",
    "smoke:desktop": "node scripts/smoke-desktop.mjs",
    "smoke:desktop-ui": "node scripts/smoke-desktop-ui.mjs",
    "start": "npm run build && electron .",
    "start:built": "electron .",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit && tsc -p renderer/tsconfig.json --noEmit"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.1",
    "electron": "^36.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.8.0",
    "vite": "^6.0.7"
  }
}
